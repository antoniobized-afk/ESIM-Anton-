generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id                      String                   @id @default(cuid())
  telegramId              BigInt?                  @unique
  username                String?
  firstName               String?
  lastName                String?
  phone                   String?                  @unique
  email                   String?                  @unique
  authProvider            String? // 'telegram' | 'phone' | 'google' | 'yandex' | 'vk'
  providerId              String? // provider-specific ID
  balance                 Decimal                  @default(0) @db.Decimal(10, 2)
  bonusBalance            Decimal                  @default(0) @db.Decimal(10, 2)
  referralCode            String                   @unique @default(cuid())
  referredById            String?
  referralLinkId          String?
  loyaltyLevelId          String?
  totalSpent              Decimal                  @default(0) @db.Decimal(10, 2)
  isBlocked               Boolean                  @default(false)
  createdAt               DateTime                 @default(now())
  updatedAt               DateTime                 @updatedAt
  utmCampaign             String?
  utmMedium               String?
  utmSource               String?
  notifications           Notification[]
  orders                  Order[]
  repeatChargeAttempts    RepeatChargeAttempt[]
  transactions            Transaction[]
  referralLinks           ReferralLink[]           @relation("OwnedReferralLinks")
  referralLink            ReferralLink?            @relation("ReferredViaLink", fields: [referralLinkId], references: [id], onDelete: Restrict)
  ownedPromoCodes         PromoCode[]              @relation("OwnedPromoCodes")
  promoCodeRedemptions    PromoCodeRedemption[]
  promoRewardSnapshots    PromoCodeRedemption[]    @relation("PromoRewardOwnerSnapshots")
  pushSubs                PushSubscription[]
  cloudPaymentsCardTokens CloudPaymentsCardToken[]
  identities              UserIdentity[]
  identityAudits          UserIdentityAudit[]
  marketingAttribution    UserMarketingAttribution? @relation("UserMarketingAttributionUser")
  marketingTouches        MarketingTouch[]          @relation("MarketingTouchUser")
  loyaltyLevel            LoyaltyLevel?            @relation(fields: [loyaltyLevelId], references: [id])
  referredBy              User?                    @relation("Referrals", fields: [referredById], references: [id])
  referrals               User[]                   @relation("Referrals")

  @@index([telegramId])
  @@index([referralCode])
  @@index([referralLinkId])
  @@index([authProvider, providerId])
  @@map("users")
}

model CloudPaymentsCardToken {
  id                   String                @id @default(cuid())
  userId               String
  accountId            String
  cloudPaymentsToken   String
  tokenFingerprint     String                @unique
  cardMask             String
  cardBrand            String?
  expMonth             Int?
  expYear              Int?
  isActive             Boolean               @default(true)
  consentCapturedAt    DateTime?
  sourceTransactionId  String?
  sourceInvoiceId      String?
  lastUsedAt           DateTime?
  deactivatedAt        DateTime?
  deactivationReason   String?
  createdAt            DateTime              @default(now())
  updatedAt            DateTime              @updatedAt
  user                 User                  @relation(fields: [userId], references: [id], onDelete: Cascade)
  repeatChargeAttempts RepeatChargeAttempt[]

  @@index([userId, isActive])
  @@index([accountId, isActive])
  @@index([sourceTransactionId])
  @@map("cloudpayments_card_tokens")
}

model PushSubscription {
  id        String   @id @default(cuid())
  userId    String
  endpoint  String   @unique
  p256dh    String
  auth      String
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("push_subscriptions")
}

model EmailCode {
  id        String   @id @default(cuid())
  email     String   @unique
  code      String
  attempts  Int      @default(0)
  expiresAt DateTime
  createdAt DateTime @default(now())

  @@map("email_codes")
}

model UserIdentity {
  id              String               @id @default(cuid())
  userId          String
  provider        AuthIdentityProvider
  providerSubject String
  email           String?
  emailVerified   Boolean              @default(false)
  displayName     String?
  linkedAt        DateTime             @default(now())
  lastLoginAt     DateTime?
  metadata        Json?
  user            User                 @relation(fields: [userId], references: [id], onDelete: Cascade)
  audits          UserIdentityAudit[]

  @@unique([provider, providerSubject])
  @@unique([userId, provider])
  @@index([userId])
  @@map("user_identities")
}

model UserIdentityAudit {
  id                     String                     @id @default(cuid())
  event                  UserIdentityAuditEvent
  identityId             String?
  userId                 String?
  actorType              UserIdentityAuditActorType
  actorId                String?
  provider               AuthIdentityProvider?
  providerSubjectHash    String?
  providerSubjectPreview String?
  reason                 String?
  before                 Json?
  after                  Json?
  metadata               Json?
  createdAt              DateTime                   @default(now())
  identity               UserIdentity?              @relation(fields: [identityId], references: [id], onDelete: SetNull)
  user                   User?                      @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@index([identityId])
  @@index([userId])
  @@index([event, createdAt])
  @@map("user_identity_audit")
}

model LoyaltyLevel {
  id              String   @id @default(cuid())
  name            String   @unique
  minSpent        Decimal  @db.Decimal(10, 2)
  cashbackPercent Decimal  @db.Decimal(5, 2)
  discount        Decimal  @default(0) @db.Decimal(5, 2)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
  users           User[]

  @@map("loyalty_levels")
}

model EsimProduct {
  id            String   @id @default(cuid())
  country       String
  region        String?
  name          String
  description   String?
  dataAmount    String
  validityDays  Int // Для дневного безлимита = срок действия (180 дней), для обычных = duration
  duration      Int? // Для дневного безлимита = 1 (в день), для обычных = validityDays
  dataType      Int?     @default(1) // eSIM Access: 1 Data in Total, 2 Daily Limit (Speed Reduced), 3 Daily Limit (Service Cut-off), 4 Daily Unlimited; null = legacy daily subtype unknown
  speed         String? // Ограничение скорости после лимита (384 Kbps, 1 Mbps и т.д.)
  providerPrice Decimal  @db.Decimal(10, 2)
  ourPrice      Decimal  @db.Decimal(10, 2)
  dataAmountMb  Decimal? @db.Decimal(14, 4)
  providerCostPerGb Decimal? @db.Decimal(18, 6)
  markupRatio   Decimal? @db.Decimal(18, 6)
  providerId    String
  providerName  String   @default("main")
  isActive      Boolean  @default(true)
  stock         Int      @default(999)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
  isUnlimited   Boolean  @default(false)
  badge         String?
  badgeColor    String?
  // Произвольные теги-пометки тарифа («Материковый Китай», «Не гонконгский IP», «5G» и т.д.)
  // Часть тегов проставляется автоматически в syncWithProvider, часть — вручную из админки.
  tags          String[] @default([])
  // Длинное человекочитаемое примечание (например, особые условия активации)
  notes         String?
  // Поддерживает ли провайдер пополнение для этого пакета (кэшируется при синхронизации,
  // чтобы не запрашивать список пакетов пополнения до того, как пользователь жмёт «Пополнить»)
  supportTopup  Boolean  @default(false)
  orders        Order[]

  @@index([country])
  @@index([isActive])
  @@index([dataType])
  @@index([dataAmountMb])
  @@index([providerCostPerGb])
  @@index([markupRatio])
  @@map("esim_products")
}

model Order {
  id                   String               @id @default(cuid())
  userId               String
  productId            String
  status               OrderStatus          @default(PENDING)
  quantity             Int                  @default(1)
  periodNum            Int?
  productPrice         Decimal              @db.Decimal(10, 2)
  discount             Decimal              @default(0) @db.Decimal(10, 2)
  promoCode            String?
  promoCodeSource      PromoCodeSource?
  promoDiscount        Decimal              @default(0) @db.Decimal(10, 2)
  bonusUsed            Decimal              @default(0) @db.Decimal(10, 2)
  totalAmount          Decimal              @db.Decimal(10, 2)
  qrCode               String?
  iccid                String?
  activationCode       String?
  providerOrderId      String?
  providerResponse     Json?
  errorMessage         String?
  createdAt            DateTime             @default(now())
  updatedAt            DateTime             @updatedAt
  completedAt          DateTime?
  completionAccountingAppliedAt DateTime?
  completionAccountingStatus CompletionAccountingStatus @default(NOT_REQUIRED)
  completionAccountingAttempts Int                  @default(0)
  completionAccountingLastAttemptAt DateTime?
  completionAccountingNextRetryAt DateTime?
  completionAccountingLastError String?
  // Кэш последнего известного использования трафика для активной eSIM (в байтах)
  lastUsageBytes       BigInt?
  // Кэш общего объёма трафика (приходит у провайдера вместе с usage),
  // нужен чтобы шкала прогресса работала и без свежего запроса к eSIM Access
  lastUsageTotalBytes  BigInt?
  // Когда usage был последний раз обновлён (для решения, нужно ли перезапрашивать у провайдера)
  lastUsageAt          DateTime?
  // Когда было отправлено последнее уведомление о низком остатке — чтобы не спамить
  lowTrafficNotifiedAt DateTime?
  // Когда было отправлено уведомление об истечении срока — чтобы не спамить
  expiryNotifiedAt     DateTime?
  // Кэш статуса eSIM, нормализованный по EsimStatus enum (см. esim-status.ts)
  // Возможные значения: NOT_INSTALLED | ACTIVE | EXPIRED | USED_UP | CANCELLED | UNKNOWN
  esimStatus           String?
  // SM-DP+ адрес от провайдера (нужен для построения LPA-строки и Universal Link Apple)
  smdpAddress          String?
  // Когда eSIM была впервые активирована (effectiveTime от провайдера)
  activatedAt          DateTime?
  // Когда eSIM истекает (expiredTime от провайдера) — приоритетнее createdAt+validityDays
  expiresAt            DateTime?
  // Top-up flow: если этот заказ — пополнение существующей eSIM, тут лежит id
  // родительского заказа (по которому изначально куплена eSIM, к этому ICCID идёт topup)
  parentOrderId        String?
  parentOrder          Order?               @relation("OrderTopups", fields: [parentOrderId], references: [id])
  topups               Order[]              @relation("OrderTopups")
  // packageCode провайдера, выбранный для пополнения (при выдаче будет передан в /esim/topup)
  topupPackageCode     String?
  product              EsimProduct          @relation(fields: [productId], references: [id])
  user                 User                 @relation(fields: [userId], references: [id])
  repeatChargeAttempt  RepeatChargeAttempt?
  promoCodeRedemption  PromoCodeRedemption?
  transactions         Transaction[]
  marketingAttribution OrderMarketingAttribution?

  @@index([userId])
  @@index([status])
  @@index([createdAt])
  @@index([parentOrderId])
  @@index([completionAccountingStatus, completionAccountingNextRetryAt], map: "orders_completion_accounting_retry_idx")
  @@map("orders")
}

model Transaction {
  id              String            @id @default(cuid())
  userId          String
  orderId         String?
  referralLinkId  String?
  promoCodeId     String?
  type            TransactionType
  status          TransactionStatus @default(PENDING)
  amount          Decimal           @db.Decimal(10, 2)
  paymentProvider String?
  paymentId       String?
  paymentMethod   String?
  metadata        Json?
  createdAt       DateTime          @default(now())
  updatedAt       DateTime          @updatedAt
  order           Order?            @relation(fields: [orderId], references: [id])
  referralLink    ReferralLink?     @relation("ReferralLinkTransactions", fields: [referralLinkId], references: [id], onDelete: Restrict)
  promoCode       PromoCode?        @relation("PromoCodeTransactions", fields: [promoCodeId], references: [id], onDelete: Restrict)
  user            User              @relation(fields: [userId], references: [id])

  @@index([userId])
  @@index([orderId])
  @@index([referralLinkId])
  @@index([promoCodeId])
  @@index([promoCodeId, type, status])
  @@index([paymentId])
  @@index([status])
  @@map("transactions")
}

model ReferralLink {
  id            String              @id @default(cuid())
  code          String              @unique
  userId        String
  label         String?
  bonusPercent  Decimal             @db.Decimal(5, 2)
  payoutMode    ReferralPayoutMode  @default(BALANCE)
  promoCodeId   String?
  isActive      Boolean             @default(true)
  expiresAt     DateTime?
  createdAt     DateTime            @default(now())
  updatedAt     DateTime            @updatedAt
  user          User                @relation("OwnedReferralLinks", fields: [userId], references: [id])
  promoCode     PromoCode?          @relation(fields: [promoCodeId], references: [id])
  referredUsers User[]              @relation("ReferredViaLink")
  transactions  Transaction[]       @relation("ReferralLinkTransactions")
  marketingCampaigns MarketingCampaign[] @relation("MarketingCampaignReferralLink")

  @@index([userId])
  @@index([promoCodeId])
  @@map("referral_links")
}

model MarketingCampaign {
  id                String   @id @default(cuid())
  shortCode         String   @unique
  name              String
  utmSource         String
  utmMedium         String
  utmCampaign       String
  utmContent        String?
  utmTerm           String?
  targetPath        String
  referralLinkId    String?
  isActive          Boolean  @default(true)
  deactivatedAt     DateTime?
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt
  referralLink      ReferralLink?                  @relation("MarketingCampaignReferralLink", fields: [referralLinkId], references: [id], onDelete: Restrict)
  touches           MarketingTouch[]
  audits            MarketingCampaignAudit[]
  registrationFirst UserMarketingAttribution[]     @relation("RegistrationFirstMarketingCampaign")
  registrationLast  UserMarketingAttribution[]     @relation("RegistrationLastMarketingCampaign")
  orderFirst        OrderMarketingAttribution[]    @relation("OrderFirstMarketingCampaign")
  orderLast         OrderMarketingAttribution[]    @relation("OrderLastMarketingCampaign")

  @@index([isActive, createdAt])
  @@index([referralLinkId])
  @@map("marketing_campaigns")
}

model MarketingTouch {
  id                                      String                @id @default(cuid())
  campaignId                              String
  userId                                  String?
  channel                                 MarketingTouchChannel
  sourceEventKey                          String                @unique
  /// DB CHECK forbids userId + visitorKeyHash together; both null remains valid after anonymization.
  visitorKeyHash                          String?
  occurredAt                              DateTime
  createdAt                               DateTime              @default(now())
  campaign                                MarketingCampaign     @relation(fields: [campaignId], references: [id], onDelete: Restrict)
  user                                    User?                 @relation("MarketingTouchUser", fields: [userId], references: [id], onDelete: SetNull)
  currentFirstForUserAttribution          UserMarketingAttribution[] @relation("UserCurrentFirstMarketingTouch")
  currentLastForUserAttribution           UserMarketingAttribution[] @relation("UserCurrentLastMarketingTouch")
  registrationFirstForUserAttribution     UserMarketingAttribution[] @relation("RegistrationFirstMarketingTouch")
  registrationLastForUserAttribution      UserMarketingAttribution[] @relation("RegistrationLastMarketingTouch")
  firstForOrderAttribution                OrderMarketingAttribution[] @relation("OrderFirstMarketingTouch")
  lastForOrderAttribution                 OrderMarketingAttribution[] @relation("OrderLastMarketingTouch")

  @@index([campaignId, occurredAt])
  @@index([userId, occurredAt])
  @@index([visitorKeyHash, occurredAt])
  @@index([channel, occurredAt])
  @@map("marketing_touches")
}

model UserMarketingAttribution {
  id                             String                                  @id @default(cuid())
  userId                         String?                                 @unique
  firstTouchId                   String?
  firstTouchOccurredAt           DateTime?
  lastTouchId                    String?
  lastTouchOccurredAt            DateTime?
  registrationStatus             MarketingRegistrationAttributionStatus @default(PENDING)
  registrationFinalizedAt        DateTime?
  registrationFirstTouchId       String?
  registrationLastTouchId        String?
  registrationFirstCampaignId    String?
  registrationFirstCampaignCode  String?
  registrationFirstCampaignName  String?
  registrationFirstUtmSource     String?
  registrationFirstUtmMedium     String?
  registrationFirstUtmCampaign   String?
  registrationFirstUtmContent    String?
  registrationFirstUtmTerm       String?
  registrationFirstChannel       MarketingTouchChannel?
  registrationFirstOccurredAt    DateTime?
  registrationLastCampaignId     String?
  registrationLastCampaignCode   String?
  registrationLastCampaignName   String?
  registrationLastUtmSource      String?
  registrationLastUtmMedium      String?
  registrationLastUtmCampaign    String?
  registrationLastUtmContent     String?
  registrationLastUtmTerm        String?
  registrationLastChannel        MarketingTouchChannel?
  registrationLastOccurredAt     DateTime?
  createdAt                      DateTime                                @default(now())
  updatedAt                      DateTime                                @updatedAt
  user                           User?                                   @relation("UserMarketingAttributionUser", fields: [userId], references: [id], onDelete: SetNull)
  firstTouch                     MarketingTouch?                         @relation("UserCurrentFirstMarketingTouch", fields: [firstTouchId], references: [id], onDelete: Restrict)
  lastTouch                      MarketingTouch?                         @relation("UserCurrentLastMarketingTouch", fields: [lastTouchId], references: [id], onDelete: Restrict)
  registrationFirstTouch         MarketingTouch?                         @relation("RegistrationFirstMarketingTouch", fields: [registrationFirstTouchId], references: [id], onDelete: Restrict)
  registrationLastTouch          MarketingTouch?                         @relation("RegistrationLastMarketingTouch", fields: [registrationLastTouchId], references: [id], onDelete: Restrict)
  registrationFirstCampaign      MarketingCampaign?                      @relation("RegistrationFirstMarketingCampaign", fields: [registrationFirstCampaignId], references: [id], onDelete: Restrict)
  registrationLastCampaign       MarketingCampaign?                      @relation("RegistrationLastMarketingCampaign", fields: [registrationLastCampaignId], references: [id], onDelete: Restrict)

  @@index([registrationStatus, registrationFinalizedAt])
  @@index([registrationFirstCampaignId])
  @@index([registrationLastCampaignId])
  @@map("user_marketing_attribution")
}

model OrderMarketingAttribution {
  id                    String                @id @default(cuid())
  orderId               String                @unique
  firstTouchId          String?
  lastTouchId           String?
  firstCampaignId       String?
  firstCampaignCode     String?
  firstCampaignName     String?
  firstUtmSource        String?
  firstUtmMedium        String?
  firstUtmCampaign      String?
  firstUtmContent       String?
  firstUtmTerm          String?
  firstChannel          MarketingTouchChannel?
  firstOccurredAt       DateTime?
  lastCampaignId        String?
  lastCampaignCode      String?
  lastCampaignName      String?
  lastUtmSource         String?
  lastUtmMedium         String?
  lastUtmCampaign       String?
  lastUtmContent        String?
  lastUtmTerm           String?
  lastChannel           MarketingTouchChannel?
  lastOccurredAt        DateTime?
  createdAt             DateTime              @default(now())
  order                 Order                 @relation(fields: [orderId], references: [id], onDelete: Restrict)
  firstTouch            MarketingTouch?       @relation("OrderFirstMarketingTouch", fields: [firstTouchId], references: [id], onDelete: Restrict)
  lastTouch             MarketingTouch?       @relation("OrderLastMarketingTouch", fields: [lastTouchId], references: [id], onDelete: Restrict)
  firstCampaign         MarketingCampaign?    @relation("OrderFirstMarketingCampaign", fields: [firstCampaignId], references: [id], onDelete: Restrict)
  lastCampaign          MarketingCampaign?    @relation("OrderLastMarketingCampaign", fields: [lastCampaignId], references: [id], onDelete: Restrict)

  @@index([firstCampaignId])
  @@index([lastCampaignId])
  @@map("order_marketing_attribution")
}

model MarketingCampaignAudit {
  id        String                      @id @default(cuid())
  campaignId String
  event     MarketingCampaignAuditEvent
  actorId   String
  actorRole AdminRole
  before    Json?
  after     Json?
  createdAt DateTime                    @default(now())
  campaign  MarketingCampaign           @relation(fields: [campaignId], references: [id], onDelete: Restrict)

  @@index([campaignId, createdAt])
  @@index([actorId, createdAt])
  @@map("marketing_campaign_audits")
}

model RepeatChargeAttempt {
  id                         String                    @id @default(cuid())
  orderId                    String                    @unique
  userId                     String
  savedCardId                String
  status                     RepeatChargeAttemptStatus @default(IN_PROGRESS)
  idempotencyKey             String                    @unique
  cloudPaymentsTransactionId String?
  providerReasonCode         Int?
  providerMessage            String?
  ambiguousReason            String?
  createdAt                  DateTime                  @default(now())
  updatedAt                  DateTime                  @updatedAt
  finishedAt                 DateTime?
  order                      Order                     @relation(fields: [orderId], references: [id], onDelete: Cascade)
  user                       User                      @relation(fields: [userId], references: [id], onDelete: Cascade)
  savedCard                  CloudPaymentsCardToken    @relation(fields: [savedCardId], references: [id], onDelete: Restrict)

  @@index([userId, status])
  @@index([savedCardId])
  @@map("repeat_charge_attempts")
}

model Notification {
  id        String           @id @default(cuid())
  userId    String
  type      NotificationType
  title     String
  message   String
  isRead    Boolean          @default(false)
  metadata  Json?
  createdAt DateTime         @default(now())
  user      User             @relation(fields: [userId], references: [id])

  @@index([userId])
  @@index([isRead])
  @@map("notifications")
}

model EsimWebhookReceipt {
  id               String                     @id @default(cuid())
  dedupKey         String                     @unique
  authMode         EsimWebhookReceiptAuthMode
  notifyType       String
  notifyId         String?
  orderNo          String?
  eventGeneratedAt DateTime?
  createdAt        DateTime                   @default(now())
  updatedAt        DateTime                   @updatedAt

  @@index([authMode, notifyType, createdAt])
  @@map("esim_webhook_receipts")
}

model PromoCode {
  id                   String                @id @default(cuid())
  code                 String                @unique
  discountPercent      Int // 1-100
  maxUses              Int? // null = безлимит
  usedCount            Int                   @default(0)
  isActive             Boolean               @default(true)
  expiresAt            DateTime?
  referralOwnerId      String?
  referralBonusPercent Decimal?              @db.Decimal(5, 2)
  referralPayoutMode   ReferralPayoutMode?
  createdAt            DateTime              @default(now())
  updatedAt            DateTime              @updatedAt
  referralOwner        User?                 @relation("OwnedPromoCodes", fields: [referralOwnerId], references: [id], onDelete: Restrict)
  referralLinks        ReferralLink[]
  redemptions          PromoCodeRedemption[]
  transactions         Transaction[]         @relation("PromoCodeTransactions")

  @@index([referralOwnerId])
  @@map("promo_codes")
}

model PromoCodeRedemption {
  id                         String                    @id @default(cuid())
  promoCodeId                String
  userId                     String
  orderId                    String?                   @unique
  source                     PromoCodeRedemptionSource
  status                     PromoCodeRedemptionStatus @default(RESERVED)
  rewardOwnerIdSnapshot      String?
  rewardBonusPercentSnapshot Decimal?                  @db.Decimal(5, 2)
  rewardPayoutModeSnapshot   ReferralPayoutMode?
  createdAt                  DateTime                  @default(now())
  consumedAt                 DateTime?
  releasedAt                 DateTime?
  promoCode                  PromoCode                 @relation(fields: [promoCodeId], references: [id])
  user                       User                      @relation(fields: [userId], references: [id])
  order                      Order?                    @relation(fields: [orderId], references: [id])
  rewardOwnerSnapshot        User?                     @relation("PromoRewardOwnerSnapshots", fields: [rewardOwnerIdSnapshot], references: [id], onDelete: Restrict)

  @@index([promoCodeId, status])
  @@index([userId, status])
  @@index([rewardOwnerIdSnapshot, status])
  // Raw partial unique index (см. миграцию 20260616120000_add_promo_once_per_user):
  // promo_code_redemptions_consumed_once_per_user UNIQUE (promoCodeId, userId) WHERE status = 'CONSUMED'.
  // Гарантия «один пользователь — один промокод» на уровне БД.
  @@map("promo_code_redemptions")
}

model SystemSettings {
  id          String   @id @default(cuid())
  key         String   @unique
  value       String
  description String?
  updatedAt   DateTime @updatedAt

  @@map("system_settings")
}

model Admin {
  id          String    @id @default(cuid())
  email       String    @unique
  password    String
  firstName   String?
  lastName    String?
  role        AdminRole @default(SUPPORT)
  isActive    Boolean   @default(true)
  lastLoginAt DateTime?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  @@map("admins")
}

enum OrderStatus {
  PENDING
  PAID
  PROCESSING
  COMPLETED
  FAILED
  REFUNDED
  CANCELLED
}

enum CompletionAccountingStatus {
  NOT_REQUIRED
  PENDING
  APPLIED
  FAILED
}

enum TransactionType {
  PAYMENT
  REFUND
  BONUS_ACCRUAL
  BONUS_SPENT
  REFERRAL_BONUS
}

enum TransactionStatus {
  PENDING
  SUCCEEDED
  FAILED
  CANCELLED
}

enum PromoCodeSource {
  MANUAL
  REFERRAL_LINK_AUTO
}

enum PromoCodeRedemptionSource {
  MANUAL
  REFERRAL_LINK_AUTO
}

enum PromoCodeRedemptionStatus {
  RESERVED
  CONSUMED
  RELEASED
