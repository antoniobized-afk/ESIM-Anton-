# Core runtime
NODE_ENV=development
DEBUG_SENSITIVE_LOGS=false
PORT=3000
CORS_ORIGIN=http://localhost:3001
BACKEND_URL=http://localhost:3000
FRONTEND_URL=http://localhost:3002
SITE_URL=https://app.mojomobile.ru

# Database
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/esim_db
REDIS_URL=redis://localhost:6379

# JWT
JWT_SECRET=change-me-to-a-long-random-secret
JWT_EXPIRES_IN=7d

# Marketing attribution node -e "console.log(require('crypto').randomBytes(32).toString('base64url'))"
MARKETING_ATTRIBUTION_VISITOR_HMAC_SECRET=change-me-to-a-long-random-secret

# Telegram
TELEGRAM_BOT_TOKEN=
TELEGRAM_BOT_USERNAME=mojo_mobile_bot
TELEGRAM_USE_WEBHOOK=false
TELEGRAM_WEBHOOK_URL=
MINI_APP_URL=http://localhost:3002
ADMIN_PANEL_URL=http://localhost:3001

# Bot runtime
API_BASE_URL=http://localhost:3000

# Public frontend/admin vars
NEXT_PUBLIC_API_URL=http://localhost:3000
NEXT_PUBLIC_BOT_USERNAME=mojo_mobile_bot
NEXT_PUBLIC_CLOUDPAYMENTS_PUBLIC_ID=
NEXT_PUBLIC_ADMIN_PIN=7391

# CloudPayments
CLOUDPAYMENTS_PUBLIC_ID=
CLOUDPAYMENTS_API_SECRET=
CLOUDPAYMENTS_TOKEN_ENCRYPTION_KEY=
# Безопасный default: production callbacks без HMAC принимать запрещено.
# Локальный unsigned smoke можно включить только явным override на false.
CLOUDPAYMENTS_ENFORCE_HMAC=true

# Robokassa legacy / fallback
ROBOKASSA_MERCHANT_LOGIN=
ROBOKASSA_PASSWORD1=
ROBOKASSA_PASSWORD2=
ROBOKASSA_TEST_MODE=true

# eSIM providers
ESIMACCESS_ACCESS_CODE=
ESIMACCESS_SECRET_KEY=
ESIM_WEBHOOK_UNSIGNED_MAX_AGE_MS=900000
ESIM_WEBHOOK_UNSIGNED_FUTURE_SKEW_MS=120000
ESIM_PRIMARY_API_URL=https://api.esimgo.com/v2
ESIM_PRIMARY_API_KEY=
ESIM_FALLBACK_API_URL=
ESIM_FALLBACK_API_KEY=

# OAuth
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
YANDEX_CLIENT_ID=
YANDEX_CLIENT_SECRET=
VK_CLIENT_ID=
VK_CLIENT_SECRET=

# Email
SMTP_HOST=
SMTP_PORT=465
SMTP_USER=
SMTP_PASS=
SMTP_FROM=noreply@mojomobile.ru

# Web push
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_SUBJECT=mailto:info@mojomobile.ru

# Traffic monitor
TRAFFIC_MONITOR_ENABLED=true
TRAFFIC_LOW_PERCENT=10
TRAFFIC_LOW_MB=100
TRAFFIC_BATCH_SIZE=50
TRAFFIC_THROTTLE_MS=250

# Referral defaults
REFERRAL_BONUS_PERCENT=5
